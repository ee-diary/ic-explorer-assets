window.STK500Flasher = (function () {

  // STK500v1 constants
  const STK = {
    OK: 0x10, INSYNC: 0x14, CRC_EOP: 0x20,
    GET_SYNC: 0x30, GET_SIGN_ON: 0x31,
    ENTER_PROGMODE: 0x50, LEAVE_PROGMODE: 0x51,
    LOAD_ADDRESS: 0x55, PROG_PAGE: 0x64,
    READ_PAGE: 0x74, READ_SIGN: 0x75,
    UNIVERSAL: 0x56,
  };

  const PAGE_SIZE = 128; // bytes — correct for ATmega328P, ATmega32
  let _port, _reader, _writer, _logFn;

  function log(msg, cls) {
    if (_logFn) _logFn(msg, cls);
  }

  // Parse Intel HEX (.hex) file into a flat byte array
  function parseHex(hexText) {
    const data = new Uint8Array(0x20000); // 128 KB max
    let maxAddr = 0;
    for (const line of hexText.split('\n')) {
      const l = line.trim();
      if (!l.startsWith(':')) continue;
      const len  = parseInt(l.slice(1, 3), 16);
      const addr = parseInt(l.slice(3, 7), 16);
      const type = parseInt(l.slice(7, 9), 16);
      if (type === 0x01) break; // EOF
      if (type !== 0x00) continue;
      for (let i = 0; i < len; i++) {
        data[addr + i] = parseInt(l.slice(9 + i * 2, 11 + i * 2), 16);
      }
      if (addr + len > maxAddr) maxAddr = addr + len;
    }
    return data.slice(0, maxAddr);
  }

  // Send bytes and wait for response
  async function send(bytes) {
    const buf = new Uint8Array(bytes);
    await _writer.write(buf);
  }

  async function readByte(timeoutMs = 2000) {
    const timer = new Promise((_, rej) =>
      setTimeout(() => rej(new Error('Read timeout')), timeoutMs));
    const read  = new Promise(async (res) => {
      while (true) {
        const { value, done } = await _reader.read();
        if (done) break;
        if (value && value.length > 0) { res(value[0]); return; }
      }
    });
    return Promise.race([read, timer]);
  }

  async function readBytes(n, timeoutMs = 3000) {
    const out = [];
    for (let i = 0; i < n; i++) out.push(await readByte(timeoutMs));
    return out;
  }

  async function expect(expected) {
    const b = await readByte();
    if (b !== expected)
      throw new Error(`Expected 0x${expected.toString(16)} got 0x${b.toString(16)}`);
  }

  async function cmd(bytes) {
    await send([...bytes, STK.CRC_EOP]);
    await expect(STK.INSYNC);
    await expect(STK.OK);
  }

  async function getSync() {
    for (let i = 0; i < 3; i++) {
      try {
        await send([STK.GET_SYNC, STK.CRC_EOP]);
        const b = await readByte(500);
        if (b === STK.INSYNC) { await readByte(500); return; }
      } catch (_) {}
    }
    throw new Error('Cannot sync — is the board connected and in bootloader mode?');
  }

  async function loadAddress(addr) {
    // STK500 uses word addresses
    const word = Math.floor(addr / 2);
    await cmd([STK.LOAD_ADDRESS, word & 0xff, (word >> 8) & 0xff]);
  }

  async function progPage(pageData) {
    const hdr = [
      STK.PROG_PAGE,
      0x00, pageData.length, // size high, low
      0x46,                  // 'F' = flash
      ...pageData,
    ];
    await cmd(hdr);
  }

  // Main flash function — call this from your sidebar widget
  async function flash(port, hexText, onLog, onProgress) {
    _port   = port;
    _logFn  = onLog;
    _reader = port.readable.getReader();
    _writer = port.writable.getWriter();

    try {
      log('Syncing with bootloader…');
      await getSync();
      log('Sync OK', 'rx');

      log('Entering programming mode…');
      await cmd([STK.ENTER_PROGMODE]);
      log('Programming mode active', 'rx');

      const data = parseHex(hexText);
      const pages = Math.ceil(data.length / PAGE_SIZE);
      log(`Flashing ${data.length} bytes (${pages} pages)…`);

      for (let p = 0; p < pages; p++) {
        const addr  = p * PAGE_SIZE;
        const chunk = data.slice(addr, addr + PAGE_SIZE);
        const page  = new Uint8Array(PAGE_SIZE);
        page.set(chunk);
        page.fill(0xff, chunk.length); // pad with 0xFF

        await loadAddress(addr);
        await progPage(Array.from(page));

        const pct = Math.round(((p + 1) / pages) * 100);
        if (onProgress) onProgress(pct);
        if (p % 4 === 0) log(`Page ${p + 1}/${pages} written`);
      }

      log('Leaving programming mode…');
      await cmd([STK.LEAVE_PROGMODE]);
      log('Flash complete!', 'rx');

    } finally {
      try { _reader.releaseLock(); } catch (_) {}
      try { _writer.releaseLock(); } catch (_) {}
    }
  }

  return { flash };
})();